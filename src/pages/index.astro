---
import BaseLayout from '@/layouts/BaseLayout.astro';
import NewsCard from '@/components/NewsCard.astro';

// Sample news data (would typically come from CMS or markdown files)
const newsItems = [
  {
    title: 'LibreELEC (Omega) 12.2.1',
    date: '2025-11-03',
    excerpt: 'LibreELEC 12.2.1 with Kodi (Omega) v21.3 is released! This update includes Kodi updated to 21.3, Linux kernel updates, and several small bug fixes.',
    slug: 'libreelec-omega-12-2-1',
  },
  {
    title: 'LibreELEC (Omega) 12.2',
    date: '2025-08-15',
    excerpt: 'LibreELEC 12.2 with Kodi (Omega) v21.2+ is released! This release brings performance improvements and enhanced hardware support.',
    slug: 'libreelec-omega-12-2',
  },
  {
    title: 'LibreELEC (Omega) 12.0.2',
    date: '2025-01-22',
    excerpt: 'LibreELEC 12.0.2 with Kodi (Omega) v21.2 has been released! Bug fixes and stability improvements for all supported platforms.',
    slug: 'libreelec-omega-12-0-2',
  },
  {
    title: 'LibreELEC USB-SD Creator v1.5',
    date: '2024-10-05',
    excerpt: 'LibreELEC USB-SD Creator v1.5 is available! New features include improved device detection and support for larger storage media.',
    slug: 'libreelec-usb-sd-creator-v1-5',
  },
  {
    title: 'LibreELEC (Omega) 12.0.1',
    date: '2024-08-26',
    excerpt: 'LibreELEC 12.0.1 with Kodi (Omega) v21.1 has been released! This maintenance release addresses several issues reported by the community.',
    slug: 'libreelec-omega-12-0-1',
  },
];
---

<BaseLayout title="Home">
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <!-- Background grid pattern -->
    <div class="absolute inset-0 bg-grid" />
    
    <!-- Gradient orbs -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary/20 rounded-full blur-3xl opacity-20" />
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-accent/20 rounded-full blur-3xl opacity-20" />
    
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
      <div class="flex flex-col items-center text-center">
        <!-- Logo Animation -->
        <div class="mb-8 glow">
          <svg width="120" height="120" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" class="animate-pulse">
            <circle cx="50" cy="50" r="45" stroke="currentColor" stroke-width="1.5" class="text-primary/40" />
            <circle cx="50" cy="50" r="35" stroke="currentColor" stroke-width="1" class="text-primary/20" />
            <path d="M50 15 L80 32.5 L80 67.5 L50 85 L20 67.5 L20 32.5 Z" fill="currentColor" class="text-primary" />
            <path d="M50 25 L70 37.5 L70 62.5 L50 75 L30 62.5 L30 37.5 Z" fill="currentColor" class="text-background" />
            <circle cx="50" cy="50" r="12" fill="currentColor" class="text-primary" />
          </svg>
        </div>
        
        <!-- Headline -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight mb-6">
          <span class="gradient-text">LibreELEC</span>
        </h1>
        
        <!-- Tagline -->
        <p class="text-xl sm:text-2xl text-muted-foreground mb-8 max-w-2xl text-balance">
          Just enough OS for <span class="text-foreground font-medium">KODI</span>
        </p>
        
        <!-- Description -->
        <p class="text-muted-foreground max-w-xl mb-10 leading-relaxed">
          A lightweight operating system built from the ground up to turn your device into a Kodi-powered media center. Fast, minimal, and optimized for entertainment.
        </p>
        
        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row items-center gap-4">
          <a
            href="/downloads"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-medium rounded-lg bg-primary text-primary-foreground hover:bg-accent transition-colors duration-200"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Download Now
          </a>
          <a
            href="https://wiki.libreelec.tv"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-medium rounded-lg border border-border text-foreground hover:bg-muted transition-colors duration-200"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
            Documentation
          </a>
        </div>
        
        <!-- Stats -->
        <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
          <div class="text-center">
            <div class="text-3xl font-bold text-foreground">10+</div>
            <div class="text-sm text-muted-foreground mt-1">Years Active</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-foreground">6</div>
            <div class="text-sm text-muted-foreground mt-1">Platforms</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-foreground">100K+</div>
            <div class="text-sm text-muted-foreground mt-1">Active Users</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-foreground">Open</div>
            <div class="text-sm text-muted-foreground mt-1">Source</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- News Section -->
  <section class="py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Section Header -->
      <div class="flex items-end justify-between mb-10">
        <div>
          <h2 class="text-2xl sm:text-3xl font-bold text-foreground mb-2">Latest News</h2>
          <p class="text-muted-foreground">Stay updated with releases and announcements</p>
        </div>
        <a
          href="/news"
          class="hidden sm:inline-flex items-center gap-2 text-sm font-medium text-primary hover:text-accent transition-colors"
        >
          View all posts
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <!-- News Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {newsItems.map((item, index) => (
          <NewsCard
            title={item.title}
            date={item.date}
            excerpt={item.excerpt}
            slug={item.slug}
            featured={index === 0}
          />
        ))}
      </div>

      <!-- Mobile View All Link -->
      <div class="mt-8 text-center sm:hidden">
        <a
          href="/news"
          class="inline-flex items-center gap-2 px-6 py-3 text-sm font-medium rounded-lg border border-border text-foreground hover:bg-muted transition-colors"
        >
          View all posts
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-16 lg:py-24 border-t border-border/50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl sm:text-3xl font-bold text-foreground mb-4">Why LibreELEC?</h2>
        <p class="text-muted-foreground max-w-2xl mx-auto">
          Purpose-built for media center use, LibreELEC delivers the perfect Kodi experience.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Feature 1 -->
        <div class="p-6 rounded-xl border border-border/50 bg-card/30 hover:border-primary/30 transition-colors duration-200">
          <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-foreground mb-2">Lightning Fast</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Boots in seconds. Minimal footprint means all resources go to Kodi for smooth 4K playback.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="p-6 rounded-xl border border-border/50 bg-card/30 hover:border-primary/30 transition-colors duration-200">
          <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-foreground mb-2">Multi-Platform</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Supports Raspberry Pi, Generic x86_64, Allwinner, Rockchip, Amlogic, and NXP devices.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="p-6 rounded-xl border border-border/50 bg-card/30 hover:border-primary/30 transition-colors duration-200">
          <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-foreground mb-2">Auto Updates</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Seamless over-the-air updates keep your system current with the latest features and security patches.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
